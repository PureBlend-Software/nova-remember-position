{
    "identifier": "com.pureblendsoftware.rememberposition",
    "name": "Remember Position",
    "organization": "PureBlend Software",
    "description": "Reopens each document scrolled to the cursor position it had the last time it was open. Provided \"as is.\" Use at your own risk.",
    "version": "1.0.1",
    "categories": ["commands"],
    "license": "MIT",
    "repository": "https://github.com/PureBlend-Software/nova-remember-position",
    "bugs": "https://github.com/PureBlend-Software/nova-remember-position/issues",
    "main": "main.js",
    "activationEvents": ["*"],
    "commands": {
        "extensions": [
            {
                "title": "Remember Position: Clear Saved Positions",
                "command": "rememberposition.clear"
            }
        ]
    }
}
